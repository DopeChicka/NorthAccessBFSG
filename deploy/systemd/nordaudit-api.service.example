[Unit]
Description=NorthAccessBFSG API (Uvicorn)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/northaccessbfsg
EnvironmentFile=/opt/northaccessbfsg/.env
Environment=PORT=8000
ExecStart=/usr/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT}
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
